---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "NetP — Network Protocol" } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="A standard protocol for describing social network datasets." />
  </head>
  <body>
    <header class="site">
      <div class="container">
        <h1><a href={base + "/"} style="text-decoration: none; color: inherit;">NetP</a></h1>
        <nav>
          <a href={base + "/"}>Home</a>
          <a href={base + "/fill"}>Fill the protocol</a>
          <a href={base + "/examples"}>Examples</a>
          <a href="https://github.com/ericquintane/protocol" target="_blank" rel="noopener">GitHub</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
